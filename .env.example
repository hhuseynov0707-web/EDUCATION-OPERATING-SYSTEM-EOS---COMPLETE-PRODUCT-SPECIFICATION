# ──────────────────────────────────────────────────────────────────────────
# EOS — Education Operating System — Environment Variables (example)
# Copy to `.env` and adjust. Never commit the real `.env`.
# ──────────────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ──
POSTGRES_USER=eos
POSTGRES_PASSWORD=eos_dev_password_change_me
POSTGRES_DB=eos
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Connection string consumed by Prisma in the backend container.
# When running via docker-compose, host is `postgres` (the service name).
DATABASE_URL=postgresql://eos:eos_dev_password_change_me@localhost:5432/eos?schema=public
# Direct (non-pooled) URL used by `prisma migrate`. Same as DATABASE_URL locally.
DIRECT_URL=postgresql://eos:eos_dev_password_change_me@localhost:5432/eos?schema=public

# ── PRODUCTION (Neon) — example shape, replace with your Neon credentials ──
# Pooled (use for DATABASE_URL): host ends with "-pooler" and needs pgbouncer flag
# DATABASE_URL=postgresql://USER:PASS@ep-xxxx-pooler.eu-central-1.aws.neon.tech/eos?sslmode=require&pgbouncer=true
# Direct (use for DIRECT_URL): no "-pooler"
# DIRECT_URL=postgresql://USER:PASS@ep-xxxx.eu-central-1.aws.neon.tech/eos?sslmode=require

# ── Redis (caching / rate limiting) ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ── Auth / JWT ──
# Generate strong secrets: `openssl rand -base64 48`
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_TTL=7d

# ── Backend (NestJS) ──
NODE_ENV=development
BACKEND_PORT=4000
# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:3000

# ── Frontend (Next.js) ──
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
FRONTEND_PORT=3000

# ── Bootstrap super admin (used by the seed script) ──
SEED_ADMIN_EMAIL=admin@eos.local
SEED_ADMIN_PASSWORD=Admin123!change
